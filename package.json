{
  "name": "rs-cross-spawn",
  "version": "0.1.2",
  "description": "Cross-platform process spawning powered by Rust — drop-in replacement for child_process.spawn with PATHEXT resolution, CMD built-in detection, and CREATE_NO_WINDOW support.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "name": "rs-cross-spawn",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "build": "napi build --platform",
    "build:release": "napi build --platform --release",
    "test": "node test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ViktorVeselov/rs-cross-spawn.git"
  },
  "keywords": [
    "spawn",
    "process",
    "cross-platform",
    "windows",
    "macos",
    "linux",
    "unix",
    "child_process",
    "exec",
    "execute",
    "command",
    "native",
    "security",
    "batbadbut",
    "rust",
    "napi-rs"
  ],
  "author": "Viktor Veselov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ViktorVeselov/rs-cross-spawn/issues"
  },
  "homepage": "https://github.com/ViktorVeselov/rs-cross-spawn#readme",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "optionalDependencies": {
    "@emnapi/runtime": "^1.3.0",
    "@rs-cross-spawn/win32-x64-msvc": "0.1.2",
    "@rs-cross-spawn/win32-arm64-msvc": "0.1.2",
    "@rs-cross-spawn/win32-ia32-msvc": "0.1.2",
    "@rs-cross-spawn/darwin-x64": "0.1.2",
    "@rs-cross-spawn/darwin-arm64": "0.1.2",
    "@rs-cross-spawn/darwin-universal": "0.1.2",
    "@rs-cross-spawn/linux-x64-gnu": "0.1.2",
    "@rs-cross-spawn/linux-x64-musl": "0.1.2",
    "@rs-cross-spawn/linux-arm64-gnu": "0.1.2",
    "@rs-cross-spawn/linux-arm64-musl": "0.1.2",
    "@rs-cross-spawn/linux-arm-gnueabihf": "0.1.2",
    "@rs-cross-spawn/linux-arm-musleabihf": "0.1.2",
    "@rs-cross-spawn/linux-riscv64-gnu": "0.1.2",
    "@rs-cross-spawn/linux-riscv64-musl": "0.1.2",
    "@rs-cross-spawn/linux-s390x-gnu": "0.1.2",
    "@rs-cross-spawn/freebsd-x64": "0.1.2",
    "@rs-cross-spawn/android-arm64": "0.1.2",
    "@rs-cross-spawn/android-arm-eabi": "0.1.2"
  }
}
